{
  "model": "sonnet[1m]",
  "language": "english",
  "effortLevel": "low",
  "tui": "fullscreen",
  "permissions": {
    "allow": [
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run ruff format:*)",
      "Bash(uv run mypy:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/*.pem)",
      "Read(./data/**)",
      "Bash(cat .env*)",
      "Bash(cat *.pem)",
      "Bash(cat data/**)"
    ]
  }
}
